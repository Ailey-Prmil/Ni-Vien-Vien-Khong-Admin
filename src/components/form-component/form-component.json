{
  "collectionName": "components_form_component_form_components",
  "info": {
    "displayName": "Form Component",
    "icon": "connector"
  },
  "options": {},
  "attributes": {
    "section": {
      "type": "enumeration",
      "default": "Thông tin khác (Others)",
      "enum": [
        "Thông tin CCCD (Identity Detail)",
        "Thông tin tu học (Monatic Detail)",
        "Thông tin thân nhân (Relation Detail)",
        "Thông tin sinh hoạt (Routine Detail)",
        "Thông tin khác (Others)"
      ]
    },
    "attributeName": {
      "type": "string",
      "required": false,
      "regex": "^[^.,!@#$%\\^&*();\"':\\[\\]{}?/|<>]+$"
    },
    "label": {
      "type": "string",
      "required": true
    },
    "isRequired": {
      "type": "boolean",
      "required": true,
      "default": false
    },
    "type": {
      "type": "enumeration",
      "enum": [
        "short text",
        "long text",
        "bool",
        "date",
        "datetime",
        "number",
        "multiple choice"
      ]
    },
    "multipleChoiceDetails": {
      "type": "component",
      "conditions": {
        "visible": {
          "==": [
            {
              "var": "type"
            },
            "multiple choice"
          ]
        }
      },
      "component": "form-component.multiple-choice",
      "repeatable": false
    }
  },
  "config": {}
}
